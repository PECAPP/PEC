{
  "name": "pec-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "api": "cd server && npx nest start --watch --swc",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "ts-node seed.ts",
    "db:check": "ts-node check_db.ts",
    "db:backup": "node scripts/db-backup.js",
    "db:backup:dry": "node scripts/db-backup.js --dry-run",
    "db:restore": "node scripts/db-restore.js",
    "db:restore:dry": "node scripts/db-restore.js --dry-run --file backup.dump",
    "db:clean": "node scripts/db-clean.js --force",
    "db:clean:confirm": "node scripts/db-clean.js",
    "db:migrate-sqlite": "node scripts/migrate-sqlite-to-postgres.js",
    "start": "nest start",
    "start:dev": "ts-node -r tsconfig-paths/register --transpile-only src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "@types/multer": "^2.1.0",
    "ajv": "^8.18.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "flatted": "^3.4.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "openapi3-ts": "^4.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "path-to-regexp": "^8.4.1",
    "pg": "^8.11.5",
    "picomatch": "^4.0.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.1",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.5.13",
    "undici": "^7.24.6",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1"
  },
  "overrides": {
    "tar": "^7.5.13",
    "undici": "^7.24.6",
    "path-to-regexp": "^8.4.1",
    "ajv": "^8.18.0",
    "picomatch": "^4.0.4",
    "handlebars": "^4.7.9",
    "flatted": "^3.4.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.5",
    "@angular-devkit/schematics": "^21.2.5",
    "@angular-devkit/schematics-cli": "^21.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
