NODE_ENV=development
PORT=3000

# Required in all environments
DATABASE_URL=postgresql://app_user:change_me@localhost:5432/omnifow
JWT_SECRET=replace-with-a-long-random-secret

# Strongly recommended for encrypted fields and abuse controls
FIELD_ENCRYPTION_KEY=replace-with-a-separate-long-random-secret
CAPTCHA_BYPASS_TOKEN=

# Session and auth hardening
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
AUTH_LOCK_THRESHOLD=5
AUTH_LOCK_MINUTES=15
REFRESH_COOKIE_NAME=refresh_token

# CORS: explicit allow-list only. Comma-separated.
CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=86400

# Request hardening
REQUEST_BODY_LIMIT=1mb

# Feature flags
FEATURE_FLAG_CACHE_TTL_MS=30000

# Background jobs / queue worker
BACKGROUND_JOB_WORKER_ENABLED=true
BACKGROUND_JOB_POLL_INTERVAL_MS=5000
BACKGROUND_JOB_STALE_LOCK_MS=60000

# Connection pooling
# Prefer a pooled Postgres URL in production, e.g. PgBouncer or managed pooler.
# Example:
# DATABASE_URL=postgresql://app_user:change_me@db.example.com:6432/omnifow?pgbouncer=true&connection_limit=10&pool_timeout=20
