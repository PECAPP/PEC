{
  "name": "pec-campus-erp",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev ",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "api": "cd server && npm run start:dev",
    "dev:all": "concurrently \"npm run api\" \"npm run dev\"",
    "dev:docker": "docker compose -f docker-compose.dev.yml up -d",
    "dev:docker:backend": "docker compose -f docker-compose.dev.yml up -d postgres backend",
    "dev:docker:frontend": "docker compose -f docker-compose.dev.yml --profile frontend up -d frontend",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f --tail=100",
    "dev:docker:restart": "docker compose -f docker-compose.dev.yml restart",
    "prod:docker": "docker compose up -d --build",
    "prod:docker:down": "docker compose down"
  },
