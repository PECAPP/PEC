{
  "name": "pec-campus-erp",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "dev:full": "concurrently --kill-others \"npm run frontend\" \"npm run api\"",
    "frontend": "next dev --turbopack -p 3000",
    "dev:fresh": "npm run clean:next && concurrently --kill-others \"npm run frontend\" \"npm run api\"",
    "api": "npm --prefix server run start:dev -- --swc",
    "build": "next build",
    "start": "next start",
    "start:fresh": "npm run clean:next && next build && next start",
    "lint": "next lint",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});console.log('cleaned .next')\"",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f --tail=100",
    "dev:docker:restart": "docker compose -f docker-compose.dev.yml restart",
    "prod:docker": "docker compose up -d --build",
    "prod:docker:down": "docker compose down",
    "setup": "npm install --legacy-peer-deps && cd server && npm install --legacy-peer-deps && npx prisma db push --accept-data-loss && npx prisma generate && npm run db:seed && cd ..",
    "clean:full": "node -e \"const fs=require('fs');['node_modules','server/node_modules','.next','server/dist'].forEach(p=>fs.rmSync(p,{recursive:true,force:true})); console.log('Cleaned all artifacts.')\""
  },
